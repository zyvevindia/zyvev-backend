# Copy to .env and fill values (never commit .env).

# --- Required (see config/env.js) ---
MONGO_URI=
JWT_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Server ---
NODE_ENV=development
PORT=5000

# --- CORS (comma-separated origins, no spaces required) ---
# Add Vercel preview URLs or alternate frontends, e.g.:
# CORS_ORIGINS=https://evsavari-git-main-org.vercel.app,https://staging.evsavari.com
CORS_ORIGINS=
