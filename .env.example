# Copy to .env and fill values (never commit .env).

# --- Required (see config/env.js) ---
MONGO_URI=
# Optional: force diagnostics on production connect (URI masked in logs)
# MONGO_DIAGNOSE=true
# MONGO_DB_NAME=zyvevDB
# Local Windows only if diagnose shows "unable to verify the first certificate":
# MONGO_TLS_INSECURE_LOCAL=true
JWT_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Server ---
NODE_ENV=development
PORT=5000

# --- CORS (comma-separated origins, no spaces required) ---
# Add Vercel preview URLs or alternate frontends, e.g.:
# CORS_ORIGINS=https://evsavari-git-main-org.vercel.app,https://staging.evsavari.com
CORS_ORIGINS=

# --- EV master catalog (integration sprint) ---
# USE_EV_MASTER=false keeps legacy Car-only reads (default, safe).
# USE_EV_MASTER=true enables dual-read merge on GET /cars and slug/id lookups.
USE_EV_MASTER=false
# Allow admin JWT + ?preview=true on /api/catalog/variants
EV_MASTER_ADMIN_PREVIEW=true

# --- SEO decision pages API ---
# SEO_PAGES_ENABLED=true serves GET /api/seo/pages/:slug (static JSON fallback on frontend works without this)
SEO_PAGES_ENABLED=false
SEO_INTELLIGENCE_PUBLIC=false

# --- Cloudflare Turnstile (low-intent forms only: feedback, contact, newsletter) ---
# Required in production (see config/env.js). Frontend: VITE_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
# Set false in staging to allow missing keys (not recommended for public launch)
# TURNSTILE_REQUIRED=false

# --- Rate limits (per IP, 15 min window) ---
# LEAD_RATE_LIMIT_MAX=5
# LOW_INTENT_RATE_LIMIT_MAX=5
# LOG_LEVEL=info
# SLOW_REQUEST_MS=2000

# --- Sentry (backend error monitoring) ---
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=evsavari-api@1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0.05
# SENTRY_ENABLED=true

# --- Buyer intent / behavioral intelligence ---
BEHAVIORAL_INTELLIGENCE_ENABLED=false
BEHAVIORAL_EVENT_RETENTION_DAYS=90
BEHAVIORAL_SESSION_HOURLY_CAP=120

# --- Operational audit log (MongoDB TTL) ---
OPS_AUDIT_RETENTION_DAYS=180
OPS_AUDIT_MAX_PAGE_SIZE=100
OPS_AUDIT_DEFAULT_PAGE_SIZE=50
